<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/formVac3">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#6D6D6D"
        android:orientation="vertical">

        <!-- Título -->

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <View
                android:id="@+id/viewVac3"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="10dp"
            android:background="@drawable/fundo_form">

            <ImageButton
                android:id="@+id/btVoltar3"
                android:layout_width="62dp"
                android:layout_height="40dp"
                android:layout_marginTop="26dp"
                android:backgroundTint="#FDFAFA"
                app:layout_constraintBottom_toTopOf="@+id/linearLayout"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.045"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="?attr/homeAsUpIndicator" />

            <ImageButton
                android:id="@+id/btFechar3"
                android:layout_width="34dp"
                android:layout_height="33dp"
                android:layout_marginTop="26dp"
                android:layout_marginEnd="28dp"
                android:backgroundTint="#FDFAFA"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@drawable/bt_fechar" />

            <LinearLayout
                android:id="@+id/linearLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="30dp"
                android:layout_marginEnd="28dp"
                android:orientation="vertical"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="1.0">



                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="Próxima Vacina"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:id="@+id/imageView3"
                        android:layout_width="183dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="15dp"
                        android:layout_marginBottom="40dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:srcCompat="@drawable/barra3" />

                </androidx.constraintlayout.widget.ConstraintLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="Próxima Dose" />



                <EditText
                    android:id="@+id/txtNome_pro_vac"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/customiza_campo"
                    android:hint="Nome da Próxima dose"
                    android:inputType="text"
                    android:padding="10dp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:textSize="16dp" />

                <EditText
                    android:id="@+id/txtData_pro_vac"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/customiza_campo"
                    android:hint="Data da Próxima dose"
                    android:inputType="date"
                    android:padding="10dp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:textSize="16dp" />
                <CheckBox
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:id="@+id/lembrar"
                    android:text="Ativar Lembrete"/>



                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="5dp"
                    android:text="Anotações" />

                <EditText
                    android:id="@+id/txtAnota_vac"
                    android:layout_width="match_parent"
                    android:layout_height="70dp"
                    android:layout_marginBottom="14dp"
                    android:height="80dp"
                    android:background="@drawable/customiza_campo"
                    android:hint="Digite aqui o máixmo de informações sobre o proxima vacina"
                    android:paddingStart="12dp"
                    android:paddingLeft="6dp"
                    android:paddingEnd="12dp"
                    android:textSize="16dp" />



                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="Arquivos impportantes" />

                <Button
                    android:id="@+id/button2"
                    style="@style/Widget.Material3.Button.Icon"
                    android:layout_width="wrap_content"
                    android:layout_height="58dp"
                    android:layout_marginBottom="25dp"
                    android:backgroundTint="#D096B4"
                    android:text="Anexe o arquivo"
                    android:textSize="14dp"
                    app:cornerRadius="8dp" />

                <Button
                    android:id="@+id/btnProximo3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:backgroundTint="#282626"
                    android:text="Próximo" />

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>



    </LinearLayout>
</ScrollView>